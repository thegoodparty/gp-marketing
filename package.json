    "@types/node": "^24.7.0",
    "@types/qs": "^6.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "chromatic": "^14.0.0--canary.1188.15686730781.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "jotai": "^2.15.0",
    "luxon": "^3.7.2",
