    "@storybook/addon-themes": "10.0.0-beta.9",
    "@storybook/addon-vitest": "10.0.0-beta.9",
    "@storybook/builder-vite": "10.0.0-beta.9",
    "@storybook/builder-webpack5": "10.0.0-beta.9",
    "@storybook/cli": "10.0.0-beta.9",
    "@storybook/codemod": "10.0.0-beta.9",
    "@storybook/csf-plugin": "10.0.0-beta.9",
    "@storybook/nextjs": "^10.0.0-beta.9",
    "@storybook/nextjs-vite": "10.0.0-beta.9",
    "@storybook/react": "^10.0.0-beta.9",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.14",
