    "react-aria-components": "^1.13.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.8",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.50.0",
    "react-instantsearch": "^7.16.3",
    "react-slugify": "^5.0.0",
    "sanity": "^4.22.0",
    "sanity-plugin-documents-pane": "^3.0.0",
    "sanity-plugin-iframe-pane": "^4.0.0",
    "sanity-plugin-media": "^4.1.1",
    "sanity-plugin-mux-input": "^2.9.0",
    "sb": "10.0.0-beta.9",
    "server-only": "^0.0.1",
    "server-only-context": "^0.1.0",
    "storybook": "^10.0.0-beta.9",
    "storybook-addon-pseudo-states": "10.0.0-beta.9",
    "storybook-addon-tag-badges": "^2.0.3--canary.99.17625997693.0",
    "styled-components": "^6.1.19",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite-plugin-svgr": "^4.5.0",
    "vwo-smartcode-nextjs": "^1.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@eslint/eslintrc": "^3.3.1",
    "@next/bundle-analyzer": "^15.5.4",
    "@sanity/eslint-config-studio": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.4",
    "eslint-plugin-storybook": "10.0.0-beta.9",
    "prettier": "^3.2.4",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "prettier": {
    "printWidth": 140,
    "arrowParens": "avoid",
    "bracketSameLine": false,
    "jsxSingleQuote": true,
    "quoteProps": "as-needed",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "useTabs": true,
    "overrides": [
      {
        "files": "*.ts",
        "options": {
          "parser": "babel-ts"
        }
      },
      {
        "files": "*.tsx",
        "options": {
          "parser": "babel-ts"
        }
      },
      {
        "files": "*.json",
        "options": {
          "useTabs": false
        }
      }
    ]
  }
}
