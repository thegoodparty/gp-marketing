    "@mux/mux-player-react": "^3.6.1",
    "@portabletext/react": "^4.0.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@sanity/assist": "^5.0.3",
    "@sanity/client": "^7.12.0",
    "@sanity/icons": "^3.7.4",
